# Your provider wallet address (Ethereum-compatible, e.g. MetaMask)
PROVIDER_WALLET=0xYourWalletAddressHere

# Service ID returned by POST /api/services on the AgentPay server
# Run: curl -X POST http://localhost:3000/api/services ...  (see README Step 3)
SERVICE_ID=svc_yourServiceIdHere

# AgentPay server base URL (default: local dev server)
AGENTPAY_URL=http://localhost:3000

# Port this example server listens on
PORT=4000
