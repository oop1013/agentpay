# Upstash Redis (required for production — omit to use in-memory mock for local dev)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Server port (optional, defaults to 3000)
PORT=3000

# On-chain USDC settlement via receiveWithAuthorization (ERC-3009) on Base Sepolia
# Both vars must be set for settlement to be active.
# If omitted, payment proofs are verified off-chain only (useful for local dev/testing).
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
PROVIDER_PRIVATE_KEY=0xyour_server_wallet_private_key_for_gas

# Demo service (created by POST /api/demo/setup — copy returned values here)
DEMO_SERVICE_ID=svc_your_demo_service_id
DEMO_PROVIDER_WALLET=0xyour_demo_provider_wallet_address

# API key for authenticated write endpoints (wallets, services, auth)
# Required in production — leave unset for local dev (endpoints are open without it)
AGENTPAY_API_KEY=your-secret-api-key

# Additional CORS origin — added to the CORS allowlist for browser-side cross-origin
# requests from your frontend or integrated services (no trailing slash)
# ADDITIONAL_CORS_ORIGIN=https://your-app.example.com
